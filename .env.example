# Fudan credentials
StuId=your_student_id
UISPsw=your_password

# Course IDs to monitor (comma-separated)
COURSE_IDS=12345,67890

# ModelScope LLM API key
DASHSCOPE_API_KEY=your_dashscope_api_key

# QQ SMTP (use authorization code, not login password)
SMTP_EMAIL=your_qq@qq.com
SMTP_PASSWORD=your_smtp_authorization_code
RECEIVER_EMAIL=receiver@example.com

# Concurrency (optional, default: 4)
MAX_WORKERS=4

# Storage (optional, defaults shown)
DATA_DIR=data
DB_PATH=data/icourse.db

# SenseVoice model (optional, defaults shown)
SENSEVOICE_MODEL_DIR=sherpa-onnx-sense-voice-zh-en-ja-ko-yue-2024-07-17
SILERO_VAD_PATH=silero_vad.onnx
